{
  "name": "forge-harness",
  "version": "0.0.0",
  "private": true,
  "description": "A tutorial-driven, from-scratch coding agent harness built in TypeScript.",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "bin": {
    "forge-harness": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json --noEmit",
    "start": "node dist/cli/index.js"
  },
  "keywords": [
    "agent",
    "coding-agent",
    "harness",
    "typescript",
    "tutorial"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.2.3",
    "openai": "^5.23.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.15"
  }
}

